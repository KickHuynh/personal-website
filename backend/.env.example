# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=personal_website_db

# JWT
# Generate a strong secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# CORS
# Dev example:  http://localhost:3000,http://localhost:8080
# Prod example: https://your-portfolio-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin seed for backend/createAdmin.js
ADMIN_FULL_NAME=Your Name
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=replace_with_a_strong_password
