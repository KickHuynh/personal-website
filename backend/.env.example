# =============================================================================
# backend/.env.example
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# =============================================================================

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=personal_website_db

# JWT — generate với: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# CORS — Frontend URLs được phép gọi API (phân cách bằng dấu phẩy)
# Dev:  http://localhost:3000,http://localhost:8080
# Prod: https://your-portfolio-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
